{
  "name": "symbiote-node",
  "version": "0.3.0-alpha.1",
  "type": "module",
  "description": "Visual Node Graph Editor + Execution Engine — extensible, themeable graph editor and runtime built on Symbiote.js",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./engine": "./engine/index.js",
    "./engine/*": "./engine/*",
    "./themes/*": "./themes/*",
    "./canvas/*": "./canvas/*",
    "./layout/*": "./layout/*",
    "./interactions/*": "./interactions/*",
    "./node/*": "./node/*",
    "./shapes/*": "./shapes/*",
    "./plugins/*": "./plugins/*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "demo": "npx -y serve -l 3000 .",
    "release:alpha": "npm version prerelease --preid=alpha && npm publish --tag alpha",
    "release:minor": "npm version minor && npm publish",
    "release:patch": "npm version patch && npm publish"
  },
  "keywords": [
    "node-editor",
    "graph-editor",
    "visual-programming",
    "node-graph",
    "symbiote",
    "web-components",
    "data-flow",
    "dag",
    "workflow-engine",
    "execution-engine"
  ],
  "peerDependencies": {
    "@symbiotejs/symbiote": ">=3.0.0",
    "ws": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RND-PRO/symbiote-node"
  },
  "author": "RND-PRO <nicothin@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
